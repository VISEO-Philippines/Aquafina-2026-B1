        <filterLogic>and</filterLogic>
        <filters>
            <field>Ready_for_Delivery__c</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <object>Opportunity</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
    <textTemplates>
        <name>tmplEmailBody</name>
        <isViewedAsPlainText>true</isViewedAsPlainText>
        <text>Hello Logistics Team,

The following opportunity has been successfully closed as Won.
Please proceed with the preparation and processing of the corresponding delivery order.

Opportunity Details
Opportunity Name: {!$Record.Name}
Account: {!$Record.Account.Name}

Delivery Contact
Name: {!varDeliveryContact.FirstName} {!varDeliveryContact.LastName}
Phone: {!varDeliveryContact.Phone}

Delivery Address
{!varDeliveryContact.MailingStreet}
{!varDeliveryContact.MailingCity}, {!varDeliveryContact.MailingState} {!varDeliveryContact.MailingPostalCode}
{!varDeliveryContact.MailingCountry}

Products to Deliver
{!varProductList}

If you have any questions or require clarification, please coordinate internally with the appropriate sales representative.
Thank you.</text>
