    <apiVersion>66.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>Append_Product_to_List</name>
        <label>Append Product to List</label>
        <locationX>706</locationX>
        <locationY>609</locationY>
        <assignmentItems>
            <assignToReference>varProductList</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>ProductList</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Loop_Over_Quote_Lines</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Initialize_Product_List</name>
        <label>Initialize Product List</label>
        <locationX>280</locationX>
        <locationY>629</locationY>
        <assignmentItems>
            <assignToReference>varProductList</assignToReference>
