        </assignmentItems>
        <connector>
            <targetReference>Loop_Over_Quote_Lines</targetReference>
        </connector>
    </assignments>
    <environments>Default</environments>
    <formulas>
        <name>DeliverySubject</name>
        <dataType>String</dataType>
        <expression>&quot;Delivery Order – &quot; &amp; $Record.Name</expression>
    </formulas>
    <formulas>
        <name>ProductList</name>
        <dataType>String</dataType>
        <expression>{!varProduct.Name} &amp; &quot; — Qty: &quot; &amp; TEXT({!Loop_Over_Quote_Lines.Quantity}) &amp; BR()</expression>
    </formulas>
    <interviewLabel>Query the Product List {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Query the Product List</label>
    <loops>
