<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Qualified_Before_Conversion</fullName>
    <active>true</active>
    <errorConditionFormula>IsConverted = TRUE &amp;&amp; ISPICKVAL(Status, &quot;Qualified&quot;) = FALSE</errorConditionFormula>
    <errorMessage>Lead must be Qualified before conversion.</errorMessage>
</ValidationRule>
